{
  "name": "honey-selling-site-commerce",
  "version": "0.1.0",
  "private": true,
  "description": "Honey shop — Medusa v2 backend. Products, prices, inventory, carts, orders, payments. Requires Postgres + Redis (VPS or external).",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "medusa build",
    "start": "medusa start",
    "dev": "medusa develop",
    "seed": "medusa exec ./src/scripts/seed.ts",
    "db:migrate": "medusa db:migrate",
    "db:setup": "medusa db:setup",
    "user:create": "medusa user",
    "format": "prettier --write \"**/*.{ts,js,json,md}\""
  },
  "dependencies": {
    "@medusajs/admin-sdk": "^2.0.0",
    "@medusajs/dashboard": "^2.0.0",
    "@medusajs/framework": "^2.0.0",
    "@medusajs/medusa": "^2.0.0",
    "awilix": "^8.0.1",
    "pg": "^8.13.0"
  },
  "devDependencies": {
    "@medusajs/test-utils": "^2.0.0",
    "@types/node": "^22.7.0",
    "prettier": "^3.3.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}
