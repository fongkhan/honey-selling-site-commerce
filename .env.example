# =============================================================================
# Medusa v2 on o2switch shared hosting (account: fongkhan)
# =============================================================================

# Database — Postgres created via cPanel.
# o2switch naming convention: fongkhan_<dbname> / fongkhan_<user>.
# Postgres usually listens on the default port; ask cPanel support if unsure.
DATABASE_URL=postgres://fongkhan_USER:PASSWORD@127.0.0.1:5432/fongkhan_DBNAME

# Redis 7 — non-standard port 6381, password required on o2switch.
# CLI to test: /opt/redis-7/src/redis-cli -p 6381 -a <password> ping
REDIS_URL=redis://:PASSWORD@127.0.0.1:6381

# Secrets (32+ chars, random)
JWT_SECRET=change-me
COOKIE_SECRET=change-me

# CORS — comma-separated origins
STORE_CORS=https://www.example.com
ADMIN_CORS=https://shop.example.com,https://shop.example.com/app
AUTH_CORS=https://www.example.com,https://shop.example.com

# Webhook fired on product / variant / price / inventory changes → Astro rebuild
BUILD_WEBHOOK_URL=https://www.example.com/__hooks/rebuild.php
BUILD_WEBHOOK_SECRET=change-me-to-a-long-random-string

# Server
PORT=9000
NODE_ENV=production
