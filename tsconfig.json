{
  "compilerOptions": {
    "target": "ES2022",
    "module": "Node16",
    "moduleResolution": "Node16",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "outDir": "./.medusa/server"
  },
  "include": ["src/**/*", "medusa-config.ts"],
  "exclude": ["node_modules", ".medusa", "dist"]
}
